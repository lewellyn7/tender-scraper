# ============================================================
# 数据库
# ============================================================
DB_USER=root
DB_PASSWORD=YOUR_DB_PASSWORD_HERE
DB_NAME=tender_scraper
DB_HOST=10.8.0.4
DB_PORT=5433
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# ============================================================
# 部署模式
# ============================================================
# self = 自用模式（免登录，所有功能开放）
# team = 团队模式（完整认证和用户管理）
DEPLOYMENT_MODE=team

# 自用模式默认管理员账号（仅 self 模式生效）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_DISPLAY_NAME=系统管理员

# ============================================================
# vLLM Embedding 服务
# ============================================================
# vLLM HTTP API 地址 (docker-compose 内部通过 host.docker.internal 访问宿主)
VLLM_EMBEDDING_URL=http://host.docker.internal:8000/v1/embeddings
# vLLM 加载的 embedding 模型
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
# 向量维度 (Qwen3-Embedding-4B 默认 1024，运行时自动探测)
VECTOR_DIM=1024
# 批量向量化每批大小
EMBED_BATCH_SIZE=32

# ============================================================
# AI API Keys (保留用于其他 AI 能力)
# ============================================================
NVIDIA_API_KEY=YOUR_NVIDIA_API_KEY_HERE
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
MINIMAX_API_KEY=YOUR_MINIMAX_API_KEY_HERE
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Proxy Configuration (optional - uncomment if needed)
# http_proxy=http://127.0.0.1:1080
# https_proxy=http://127.0.0.1:1080

# ============================================================
# Telegram Bot 通知
# ============================================================
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# Grafana
GRAFANA_PASSWORD=YOUR_GRAFANA_PASSWORD_HERE

# Redis
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

# Server
PORT=9099
HOST=0.0.0.0
ENV=development
LOG_LEVEL=DEBUG

# RAGFlow Configuration
RAGFLOW_MCP_URL=http://host.docker.internal:9382
RAGFLOW_BASE_URL=http://host.docker.internal:8088
RAGFLOW_API_KEY=YOUR_RAGFLOW_API_KEY_HERE
RAGFLOW_DATASET_ID=your-dataset-id

# Collection tuning
DETAIL_MAX_CONCURRENT=5   # 详情页并行采集上限
